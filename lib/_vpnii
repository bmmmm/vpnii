#compdef vpnii
# zsh completion for vpnii. Autoloaded — make sure the directory of this
# file is on $fpath before `compinit` runs (vpnii.plugin.zsh handles that
# for the standard install path).

_vpnii() {
  local -a subcmds
  subcmds=(
    'up:bring tunnel up (or pick interactively)'
    'down:bring tunnel down (or pick from active)'
    'toggle:flip tunnel state (up/down)'
    'reconnect:down + up (fix stale handshake / DERP)'
    'list:list active tunnels'
    'status:human-readable status line'
    'statusline:fixed-width status (cc-statusline / tmux)'
    'where:show what each tunnel routes + default route'
    'peers:per-peer table (handshake, endpoint, bytes)'
    'ip:show current external IP'
    'clear:remove manual cache state'
    'diag:show full vpnii status'
    'dns:toggle macOS DNS resolver (home/public/dhcp/show)'
    'setup:maintain configs / first-time wizard'
    'install:copy a clean wg config to /etc/wireguard'
    'export:strip vpnii hooks from a wg config'
    'edit:open a config in $EDITOR'
    'verify:pre-flight a wg config (sections, key shapes, hooks)'
    'rename:rename a config + cache marker'
    'help:show usage'
  )

  if (( CURRENT == 2 )); then
    _describe -t commands 'vpnii command' subcmds
    return
  fi

  local cmd="${words[2]}"
  case "$cmd" in
    up|toggle|reconnect)
      local -a names
      # wg-quick configs
      local conf
      for conf in /etc/wireguard/*.conf(N.); do
        names+=("${conf:t:r}")
      done
      # tailscale (always offered when enabled)
      [[ "${VPNII_TS_ENABLED:-1}" == "1" ]] && names+=("${VPNII_TS_NAME:-ts}")
      _describe -t tunnels 'tunnel' names
      ;;
    peers)
      local -a active
      local f
      for f in "${VPNII_WG_DIR:-/var/run/wireguard}"/*.name(N.); do
        active+=("${f:t:r}")
      done
      [[ "${VPNII_TS_ENABLED:-1}" == "1" ]] && active+=("${VPNII_TS_NAME:-ts}")
      _describe -t tunnels 'tunnel' active
      ;;
    down)
      local -a active
      # wg-quick / cache markers
      local f
      for f in "${VPNII_WG_DIR:-/var/run/wireguard}"/*.name(N.); do
        active+=("${f:t:r}")
      done
      for f in "${VPNII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/vpnii}"/*(N.); do
        active+=("${f:t}")
      done
      # tailscale, only when an interface holds a CGNAT IP. The
      # _vpnii_tailscale_active helper is sourced via vpnii.plugin.zsh
      # before compinit runs, so it's available when this completion fires.
      if [[ "${VPNII_TS_ENABLED:-1}" == "1" ]] \
        && (( ${+functions[_vpnii_tailscale_active]} )) \
        && _vpnii_tailscale_active; then
        active+=("${VPNII_TS_NAME:-ts}")
      fi
      _describe -t tunnels 'active tunnel' active
      ;;
    setup|install|export|verify)
      _files -g '*.conf'
      ;;
    edit|rename)
      local -a names
      local conf
      for conf in /etc/wireguard/*.conf(N.); do
        names+=("${conf:t:r}")
      done
      _describe -t tunnels 'tunnel' names
      ;;
    ip)
      local -a flags=('-4:IPv4 (default)' '-6:IPv6')
      _describe -t flags 'address family' flags
      ;;
    dns)
      local -a modes=(
        'show:display current DNS state'
        'home:Pi-hole + 1.1.1.1 (IPv4-only, locks IPv6 bypass)'
        'public:1.1.1.1 + 1.0.0.1 (foreign LAN / mobile)'
        'dhcp:clear override → DHCP-default'
        'services:list networksetup services (debug)'
      )
      _describe -t modes 'dns mode' modes
      ;;
  esac
}

_vpnii "$@"
