#!/usr/bin/env zsh
# vpnii-state — manage VPN tunnel state for vpnii
#
# Usage:
#   vpnii-state up <tunnel>    mark tunnel active
#   vpnii-state down <tunnel>  mark tunnel inactive
#   vpnii-state list           list active tunnels (one per line)
#   vpnii-state status         human-readable status
#   vpnii-state clear          clear all active tunnels
#
# wg-quick integration (run as user, not root):
#   PostUp  = su -c 'vpnii-state up %i' - yourusername
#   PreDown = su -c 'vpnii-state down %i' - yourusername
#
# %i is replaced by wg-quick with the interface name.

set -euo pipefail

VPNII_CACHE_DIR="${VPNII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/vpnii}"
VPNII_SYM_VPN="${VPNII_SYM_VPN:-⬡}"

_die() { printf 'vpnii-state: %s\n' "$*" >&2; exit 1; }
_usage() {
  printf 'usage: vpnii-state up <tunnel> | down <tunnel> | list | status | clear\n' >&2
  exit 1
}

[[ $# -eq 0 ]] && _usage
cmd="$1"; shift

case "$cmd" in
  up)
    [[ $# -eq 1 ]] || _die "up requires a tunnel name"
    mkdir -p "$VPNII_CACHE_DIR"
    touch "${VPNII_CACHE_DIR}/${1}"
    ;;
  down)
    [[ $# -eq 1 ]] || _die "down requires a tunnel name"
    rm -f "${VPNII_CACHE_DIR}/${1}"
    ;;
  list)
    [[ -d "$VPNII_CACHE_DIR" ]] || exit 0
    for f in "$VPNII_CACHE_DIR"/*(N); do
      [[ -f "$f" ]] && printf '%s\n' "${f:t}"
    done
    ;;
  status)
    [[ -d "$VPNII_CACHE_DIR" ]] || { printf 'no active tunnels\n'; exit 0; }
    tunnels=()
    for f in "$VPNII_CACHE_DIR"/*(N); do
      [[ -f "$f" ]] && tunnels+=("${f:t}")
    done
    if (( ${#tunnels} == 0 )); then
      printf 'no active tunnels\n'
    else
      printf '%s %s\n' "$VPNII_SYM_VPN" "${(j:, :)tunnels}"
    fi
    ;;
  clear)
    [[ -d "$VPNII_CACHE_DIR" ]] && rm -f "${VPNII_CACHE_DIR}/"*(N)
    ;;
  *)
    _usage
    ;;
esac
