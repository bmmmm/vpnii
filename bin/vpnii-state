#!/usr/bin/env zsh
# vpnii-state — manage VPN tunnel state for vpnii
#
# Usage:
#   vpnii-state up <tunnel>    mark tunnel active
#   vpnii-state down <tunnel>  mark tunnel inactive
#   vpnii-state list           list active tunnels (one per line, all sources)
#   vpnii-state status         human-readable status (all sources)
#   vpnii-state clear          clear all manual state files
#
# wg-quick integration is automatic on macOS via /var/run/wireguard/<name>.name —
# no PostUp/PreDown hooks needed. Use up/down only for VPN tools that don't use
# wg-quick (Passepartout, manual scripts).

set -euo pipefail

# Source library for shared detection logic. The hook in lib/vpnii.zsh is
# guarded against non-interactive shells, so this is side-effect free.
VPNII_HOME="${0:A:h:h}"
source "${VPNII_HOME}/lib/vpnii.zsh"

_die() { printf 'vpnii-state: %s\n' "$*" >&2; exit 1; }
_usage() {
  printf 'usage: vpnii-state up <tunnel> | down <tunnel> | list | status | clear\n' >&2
  exit 1
}

# Reject names that would escape the cache dir or hide as dotfiles.
_validate_name() {
  if [[ -z "$1" || "$1" == */* || "$1" == .* ]]; then
    _die "invalid tunnel name: $1"
  fi
}

[[ $# -eq 0 ]] && _usage
cmd="$1"; shift

case "$cmd" in
  up)
    [[ $# -eq 1 ]] || _die "up requires a tunnel name"
    _validate_name "$1"
    if [[ -f "${VPNII_WG_DIR}/${1}.name" ]]; then
      printf 'vpnii-state: %s is already up via wg-quick — no manual state needed\n' "$1" >&2
      exit 0
    fi
    mkdir -p "$VPNII_CACHE_DIR"
    touch "${VPNII_CACHE_DIR}/${1}"
    ;;
  down)
    [[ $# -eq 1 ]] || _die "down requires a tunnel name"
    _validate_name "$1"
    cache_file="${VPNII_CACHE_DIR}/${1}"
    wg_marker="${VPNII_WG_DIR}/${1}.name"
    # Idempotent: never fail. wg-quick may legitimately call us via legacy
    # PreDown hooks while .name still exists — failing here breaks tunnel teardown.
    if [[ -f "$cache_file" ]]; then
      rm -f "$cache_file"
    elif [[ -f "$wg_marker" ]]; then
      printf 'vpnii-state: %s is managed by wg-quick — to bring it down use: sudo wg-quick down %s\n' "$1" "$1" >&2
    fi
    ;;
  list)
    vpnii_active_tunnels || true
    ;;
  status)
    # `reply` is zsh's conventional out-array; _vpnii_collect_tunnels resets it.
    _vpnii_collect_tunnels
    if (( ${#reply} == 0 )); then
      printf 'no active tunnels\n'
    else
      printf '%s %s\n' "$VPNII_SYM_VPN" "${(j:, :)reply}"
    fi
    ;;
  clear)
    if [[ -d "$VPNII_CACHE_DIR" ]]; then
      rm -f "${VPNII_CACHE_DIR}/"*(N.)
    fi
    ;;
  *)
    _usage
    ;;
esac
