#!/usr/bin/env zsh
# vpnii-wg-setup — manage vpnii-state hooks in a WireGuard config
#
# Edits ONLY PostUp/PreDown lines. Never reads or displays secret values.
# Creates a .vpnii-bak backup before modifying.
#
# Usage:
#   sudo vpnii-wg-setup --clean <config.conf>   remove all vpnii-state hooks
#   sudo vpnii-wg-setup        <config.conf>    (legacy: add vpnii-state hooks)

set -euo pipefail

_die()  { printf 'vpnii-wg-setup: %s\n' "$*" >&2; exit 1; }
_info() { printf '  → %s\n' "$*"; }
_ok()   { printf '  ✓ %s\n' "$*"; }

mode="add"
if [[ "${1:-}" == "--clean" ]]; then
  mode="clean"
  shift
fi

[[ $# -eq 1 ]] || _die "usage: sudo vpnii-wg-setup [--clean] <wireguard-config.conf>"
config="$1"
[[ -f "$config" ]] || _die "not found: $config"
[[ -r "$config" ]] || _die "not readable: $config (try sudo)"
[[ -w "$config" ]] || _die "not writable: $config (try sudo)"

tunnel_name="${config:t:r}"
printf 'vpnii-wg-setup: %s  [mode: %s]\n' "$config" "$mode"
_info "tunnel name: $tunnel_name"

if [[ "$mode" == "clean" ]]; then
  # Already clean?
  if ! grep -qE "vpnii" "$config" 2>/dev/null; then
    _ok "already clean — nothing to do"
    exit 0
  fi
else
  # Absolute path to vpnii-state — wg-quick runs with minimal PATH
  vpnii_state="${0:A:h}/vpnii-state"
  [[ -x "$vpnii_state" ]] || _die "vpnii-state not found at: $vpnii_state"
  _info "vpnii-state: $vpnii_state"
  # Already migrated?
  if grep -qE "^PostUp.*sudo -u.*vpnii-state up ${tunnel_name}" "$config" 2>/dev/null; then
    _ok "already migrated — nothing to do"
    exit 0
  fi
fi

backup="${config}.vpnii-bak"
cp "$config" "$backup"
_info "backup: $backup"

tmpfile=$(mktemp)
trap 'rm -f "$tmpfile"' EXIT

python3 - "$config" "$tmpfile" "${vpnii_state:-}" "$tunnel_name" "$mode" <<'PYEOF'
import sys, re

src, dst, vpnii_bin, tunnel_name, mode = sys.argv[1:]

# Strips ALL known vpnii-state patterns from PostUp:
#   old claudii: && mkdir -p ...cache/claudii && echo "X" > .../claudii/vpnii
#   su -c form:  && su -c 'vpnii-state ...' - $SUDO_USER
#   sudo form:   && sudo -u $SUDO_USER /path/vpnii-state up <anything>
STRIP_POSTUP = re.compile(
    r'\s*&&\s*(?:'
    r'mkdir\s+-p\s+\S*\.cache\S*\s*&&\s*echo\s+"[^"]*"\s*>\s*\S*/vpnii'
    r"|su\s+-c\s+'vpnii-state[^']*'\s+-\s+\S+"
    r'|sudo\s+-u\s+\S+\s+\S*vpnii-state\s+\S+\s+\S+'
    r')'
)

# Strips ALL known vpnii-state patterns from PreDown:
#   old claudii path: /path/.cache/claudii/vpnii
#   su -c form:       && su -c 'vpnii-state ...' - $SUDO_USER
#   sudo form:        && sudo -u $SUDO_USER /path/vpnii-state down <anything>
STRIP_PREDOWN = re.compile(
    r'(?:'
    r'\s+\S+/\.cache\S*/vpnii\b'
    r"|su\s+-c\s+'vpnii-state[^']*'\s+-\s+\S+"
    r'|\s*&&\s*sudo\s+-u\s+\S+\s+\S*vpnii-state\s+\S+\s+\S+'
    r')'
)

with open(src) as f:
    lines = f.readlines()

out = []
for line in lines:
    if re.match(r'^PostUp\s*=', line):
        patched = STRIP_POSTUP.sub('', line.rstrip('\n'))
        if mode == 'add':
            patched += f" && sudo -u $SUDO_USER {vpnii_bin} up {tunnel_name}"
        out.append(patched + '\n')
    elif re.match(r'^PreDown\s*=', line):
        patched = STRIP_PREDOWN.sub('', line.rstrip('\n'))
        if mode == 'add':
            patched += f" && sudo -u $SUDO_USER {vpnii_bin} down {tunnel_name}"
        out.append(patched + '\n')
    else:
        out.append(line)

with open(dst, 'w') as f:
    f.writelines(out)
PYEOF

if [[ "$mode" == "add" ]]; then
  if ! grep -qE "^PostUp.*sudo -u.*vpnii-state up ${tunnel_name}" "$tmpfile"; then
    cp "$backup" "$config"
    _die "patch failed — restored backup"
  fi
fi

cp "$tmpfile" "$config"
_ok "PostUp updated"
_ok "PreDown updated"
printf '\nResult:\n'
grep -E '^(PostUp|PreDown)' "$config"

if [[ "$mode" == "add" ]]; then
  printf '\nRestart tunnel now? [y/N] '
  read -r answer
  if [[ "${answer:l}" == "y" ]]; then
    printf '  → wg-quick down %s\n' "$tunnel_name"
    wg-quick down "$tunnel_name" 2>/dev/null || true
    printf '  → wg-quick up %s\n' "$tunnel_name"
    wg-quick up "$tunnel_name"
    _ok "tunnel restarted"
  else
    printf '\nRun: sudo wg-quick down %s && sudo wg-quick up %s\n' "$tunnel_name" "$tunnel_name"
  fi
fi
