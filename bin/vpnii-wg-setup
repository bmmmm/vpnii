#!/usr/bin/env zsh
# vpnii-wg-setup — patch a WireGuard config to use vpnii-state
#
# Edits ONLY PostUp/PreDown lines. Never reads or displays secret values.
# Creates a .bak backup before modifying.
#
# Usage: sudo vpnii-wg-setup <config.conf>
# Example: sudo vpnii-wg-setup /etc/wireguard/HomeLab.conf

set -euo pipefail

_die()  { printf 'vpnii-wg-setup: %s\n' "$*" >&2; exit 1; }
_info() { printf '  → %s\n' "$*"; }
_ok()   { printf '  ✓ %s\n' "$*"; }

[[ $# -eq 1 ]] || _die "usage: sudo vpnii-wg-setup <wireguard-config.conf>"
config="$1"
[[ -f "$config" ]] || _die "not found: $config"
[[ -r "$config" ]] || _die "not readable: $config (try sudo)"
[[ -w "$config" ]] || _die "not writable: $config (try sudo)"

# Absolute path to vpnii-state — wg-quick runs with minimal PATH
vpnii_state="${0:A:h}/vpnii-state"
[[ -x "$vpnii_state" ]] || _die "vpnii-state not found at: $vpnii_state"

# Tunnel name = config filename without extension (e.g. HomeLab)
tunnel_name="${config:t:r}"

printf 'vpnii-wg-setup: %s\n' "$config"
_info "tunnel name: $tunnel_name"
_info "vpnii-state: $vpnii_state"

# Already migrated with correct tunnel name?
if grep -qE "^PostUp.*sudo -u.*vpnii-state up ${tunnel_name}" "$config" 2>/dev/null; then
  _ok "already migrated — nothing to do"
  exit 0
fi

# Backup
backup="${config}.vpnii-bak"
cp "$config" "$backup"
_info "backup: $backup"

tmpfile=$(mktemp)
trap 'rm -f "$tmpfile"' EXIT

python3 - "$config" "$tmpfile" "$vpnii_state" "$tunnel_name" <<'PYEOF'
import sys, re, os

src, dst, vpnii_bin, tunnel_name = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

# Strip ALL historical vpnii state patterns from PostUp — covers every migration variant:
#   old claudii: && mkdir -p ...cache/claudii && echo "X" > .../claudii/vpnii
#   su -c form:  && su -c 'vpnii-state ...' - $SUDO_USER
#   sudo %i:     && sudo -u $SUDO_USER /path/vpnii-state up %i
#   sudo utunN:  && sudo -u $SUDO_USER /path/vpnii-state up utun9
#   sudo name:   && sudo -u $SUDO_USER /path/vpnii-state up HomeLab  (re-patch)
STRIP_POSTUP = re.compile(
    r'\s*&&\s*(?:'
    r'mkdir\s+-p\s+\S*\.cache\S*\s*&&\s*echo\s+"[^"]*"\s*>\s*\S*/vpnii'
    r"|su\s+-c\s+'vpnii-state[^']*'\s+-\s+\S+"
    r'|sudo\s+-u\s+\S+\s+\S*vpnii-state\s+\S+\s+\S+'
    r')'
)

# Strip ALL historical vpnii state patterns from PreDown:
#   old claudii path: /path/.cache/claudii/vpnii (as rm -f argument)
#   su -c form:       && su -c 'vpnii-state ...' - $SUDO_USER
#   sudo form:        && sudo -u $SUDO_USER /path/vpnii-state down X
STRIP_PREDOWN = re.compile(
    r'(?:'
    r'\s+\S+/\.cache\S*/vpnii\b'
    r"|su\s+-c\s+'vpnii-state[^']*'\s+-\s+\S+"
    r'|\s*&&\s*sudo\s+-u\s+\S+\s+\S*vpnii-state\s+\S+\s+\S+'
    r')'
)

NEW_POSTUP  = f" && sudo -u $SUDO_USER {vpnii_bin} up {tunnel_name}"
NEW_PREDOWN = f" && sudo -u $SUDO_USER {vpnii_bin} down {tunnel_name}"

with open(src) as f:
    lines = f.readlines()

out = []
changed_postup = changed_predown = False
for line in lines:
    if re.match(r'^PostUp\s*=', line):
        patched = STRIP_POSTUP.sub('', line.rstrip('\n'))
        patched += NEW_POSTUP
        out.append(patched + '\n')
        changed_postup = True
    elif re.match(r'^PreDown\s*=', line):
        patched = STRIP_PREDOWN.sub('', line.rstrip('\n'))
        patched += NEW_PREDOWN
        out.append(patched + '\n')
        changed_predown = True
    else:
        out.append(line)

if not (changed_postup or changed_predown):
    print("WARN: no PostUp/PreDown found", file=sys.stderr)

with open(dst, 'w') as f:
    f.writelines(out)
PYEOF

# Verify correct tunnel name is present
if ! grep -qE "^PostUp.*sudo -u.*vpnii-state up ${tunnel_name}" "$tmpfile"; then
  cp "$backup" "$config"
  _die "patch failed — restored backup"
fi

cp "$tmpfile" "$config"
_ok "PostUp updated"
_ok "PreDown updated"
printf '\nResult:\n'
grep -E '^(PostUp|PreDown)' "$config"
printf '\nRun: sudo wg-quick down %s && sudo wg-quick up %s\n' "$tunnel_name" "$tunnel_name"
