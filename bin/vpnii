#!/usr/bin/env zsh
# vpnii — VPN status indicator CLI
#
# Subcommands:
#   vpnii up [<tunnel> [<profile>]]   bring tunnel up. wg-quick if a config
#                           exists, manual cache otherwise. tailscale (or
#                           VPNII_TS_NAME) routes to `tailscale up`, with
#                           an optional profile for multi-tailnet setups.
#                           No arg = pick from /etc/wireguard.
#   vpnii down [<tunnel>]   bring tunnel down (wg-quick / cache / tailscale).
#                           No arg = pick from active.
#   vpnii list              list active tunnels (all sources, one per line)
#   vpnii status            human-readable: "⬡ HomeLab" or "no active tunnels"
#   vpnii clear             remove all manual state files (wg-quick unaffected)
#   vpnii diag              show full vpnii status
#   vpnii setup [-y] [<conf>...]    interactive: chown wg configs, strip stale hooks
#                                   (-y / --yes auto-accepts every prompt)
#   vpnii install [-y] [-n NAME] <conf>
#                                   copy a clean wg config to /etc/wireguard/
#                                   with the right ownership; checks deps
#   vpnii export [-y] <conf> [<dir>]
#                                   read a wg config, strip vpnii hooks, write
#                                   the clean version to <dir>/<name>.conf
#                                   (default <dir> is the current directory)
#
# Implementation lives in lib/ — bin/vpnii is just the dispatcher.

set -euo pipefail
# Restrictive umask: any new file we write (config skeleton, paste target,
# cache markers) lands at mode 0600 even before an explicit chmod, so a
# Ctrl+C between write and chmod can't leave a world-readable PrivateKey.
umask 077

VPNII_HOME="${0:A:h:h}"
source "${VPNII_HOME}/lib/vpnii.zsh"
source "${VPNII_HOME}/lib/ui.zsh"
source "${VPNII_HOME}/lib/strip.zsh"
source "${VPNII_HOME}/lib/cmd-tunnel.zsh"
source "${VPNII_HOME}/lib/cmd-tailscale.zsh"
source "${VPNII_HOME}/lib/cmd-toggle.zsh"
source "${VPNII_HOME}/lib/cmd-ip.zsh"
source "${VPNII_HOME}/lib/cmd-diag.zsh"
source "${VPNII_HOME}/lib/cmd-setup.zsh"
source "${VPNII_HOME}/lib/cmd-wizard.zsh"
source "${VPNII_HOME}/lib/cmd-install.zsh"
source "${VPNII_HOME}/lib/cmd-export.zsh"

_usage() {
  cat >&2 <<'EOF'
usage: vpnii <command> [args]

Tunnel state:
  up [<tunnel> [<profile>]]
                       bring up. With no arg: picks from /etc/wireguard configs.
                       sudo wg-quick when a config exists; manual cache fallback.
                       <tunnel>=tailscale (or VPNII_TS_NAME, default 'ts'):
                       runs 'tailscale up'. <profile> picks a tailnet when more
                       than one is configured (else prompts).
  down [<tunnel>]      bring down. With no arg: picks from active tunnels (incl.
                       tailscale when up). 'tailscale' runs 'tailscale down'.
  toggle <tunnel>      flip state: up if down, down if up
  reconnect <tunnel>   down + up in one step (fixes stale handshakes / DERP)
  list                 list active tunnels — one per line (excludes tailscale)
  status               human-readable: "⬡ HomeLab  ⬢ ts" / "⊖ off"
  ip [-4 | -6]         show current external IP (sanity check after up/down)
  clear                remove all manual state files (wg-quick unaffected)

Tools:
  diag                 show full vpnii status
  setup [-y] [<conf>...]
                       interactive: chown wireguard configs and strip stale hooks
                       (no args = scan /etc/wireguard, args = specific files;
                        -y/--yes auto-accepts every prompt)
  install [-y] [-n NAME] <conf>
                       copy a clean wg config to /etc/wireguard/<name>.conf,
                       chown to current user; rejects configs with vpnii hooks
  export [-y] <conf> [<dir>]
                       read a wg config, strip vpnii hooks, write the clean
                       version to <dir>/<name>.conf (default <dir>: cwd)
EOF
  exit 1
}

[[ $# -eq 0 ]] && _usage
cmd="$1"; shift

case "$cmd" in
  up)             _cmd_up "$@" ;;
  down)           _cmd_down "$@" ;;
  toggle)         _cmd_toggle "$@" ;;
  reconnect)      _cmd_reconnect "$@" ;;
  list)           _cmd_list ;;
  status)         _cmd_status ;;
  ip)             _cmd_ip "$@" ;;
  clear)          _cmd_clear ;;
  diag)           _cmd_diag ;;
  setup)          _cmd_setup "$@" ;;
  install)        _cmd_install "$@" ;;
  export)         _cmd_export "$@" ;;
  -h|--help|help) _usage ;;
  *)              _die "unknown command: $cmd  (try 'vpnii help')" ;;
esac
