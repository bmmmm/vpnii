#!/usr/bin/env zsh
# vpnii — VPN status indicator + WireGuard / Tailscale CLI
#
# Run `vpnii help` for the full subcommand list. Implementation lives in
# lib/ — bin/vpnii is just the dispatcher.

set -euo pipefail
# Restrictive umask: any new file we write (config skeleton, paste target,
# cache markers) lands at mode 0600 even before an explicit chmod, so a
# Ctrl+C between write and chmod can't leave a world-readable PrivateKey.
umask 077

VPNII_HOME="${0:A:h:h}"
source "${VPNII_HOME}/lib/vpnii.zsh"
source "${VPNII_HOME}/lib/ui.zsh"
source "${VPNII_HOME}/lib/strip.zsh"
source "${VPNII_HOME}/lib/cmd-tunnel.zsh"
source "${VPNII_HOME}/lib/cmd-tailscale.zsh"
source "${VPNII_HOME}/lib/cmd-toggle.zsh"
source "${VPNII_HOME}/lib/cmd-where.zsh"
source "${VPNII_HOME}/lib/cmd-statusline.zsh"
source "${VPNII_HOME}/lib/cmd-peers.zsh"
source "${VPNII_HOME}/lib/cmd-config.zsh"
source "${VPNII_HOME}/lib/cmd-ip.zsh"
source "${VPNII_HOME}/lib/cmd-diag.zsh"
source "${VPNII_HOME}/lib/cmd-setup.zsh"
source "${VPNII_HOME}/lib/cmd-wizard.zsh"
source "${VPNII_HOME}/lib/cmd-install.zsh"
source "${VPNII_HOME}/lib/cmd-export.zsh"
source "${VPNII_HOME}/lib/cmd-dns.zsh"

_usage() {
  cat >&2 <<'EOF'
usage: vpnii <command> [args]

Tunnel state:
  up [<tunnel> [<profile>]]   bring up (wg-quick / cache / tailscale).
                              <profile> picks a tailnet when several configured.
  down [<tunnel>]             bring down (auto-pick from active incl. tailscale)
  toggle <tunnel>             flip state (up if down, down if up)
  reconnect <tunnel>          down + up (fixes stale handshakes / DERP relay)

Status:
  list                        active wg tunnels — one per line
  status                      "⬡ HomeLab  ⬢ ts" / "⊖ off"
  statusline                  fixed-width status (cc-statusline / tmux)
  where                       what each tunnel routes + default route
  peers <tunnel>              per-peer table (handshake, endpoint, bytes)
  ip [-4 | -6]                external IP via DNS (sanity check after up/down)
  diag                        full status (handshake age, tailscale account)
  dns <mode>                  toggle macOS DNS resolver
                              (home / public / dhcp / show / services)
  clear                       remove all manual state files

Configs:
  setup [-y] [<conf>...]      adaptive: maintenance / first-time wizard
  install [-y] [-n NAME] <conf>     copy clean wg config to /etc/wireguard
  export  [-y] <conf> [<dir>]       strip vpnii hooks, write a clean copy
  edit <tunnel>               open /etc/wireguard/<name>.conf in $EDITOR
  verify <conf>               pre-flight (sections, key shapes, hooks)
  rename <old> <new>          rename config + cache marker (refuses if up)

Env: VPNII_TS_NAME (default "ts"), VPNII_TS_ENABLED, VPNII_STATUSLINE_*.
EOF
  exit 1
}

[[ $# -eq 0 ]] && _usage
cmd="$1"; shift

case "$cmd" in
  up)             _cmd_up "$@" ;;
  down)           _cmd_down "$@" ;;
  toggle)         _cmd_toggle "$@" ;;
  reconnect)      _cmd_reconnect "$@" ;;
  list)           _cmd_list ;;
  status)         _cmd_status ;;
  statusline)     _cmd_statusline ;;
  where)          _cmd_where ;;
  peers)          _cmd_peers "$@" ;;
  ip)             _cmd_ip "$@" ;;
  clear)          _cmd_clear ;;
  diag)           _cmd_diag ;;
  dns)            _cmd_dns "$@" ;;
  setup)          _cmd_setup "$@" ;;
  install)        _cmd_install "$@" ;;
  export)         _cmd_export "$@" ;;
  edit)           _cmd_edit "$@" ;;
  verify)         _cmd_verify "$@" ;;
  rename)         _cmd_rename "$@" ;;
  -h|--help|help) _usage ;;
  *)              _die "unknown command: $cmd  (try 'vpnii help')" ;;
esac
