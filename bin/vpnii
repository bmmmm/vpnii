#!/usr/bin/env zsh
# vpnii — VPN status indicator CLI
#
# Subcommands:
#   vpnii up <tunnel>       mark tunnel active (manual cache)
#   vpnii down <tunnel>     mark tunnel inactive (manual cache)
#   vpnii list              list active tunnels (all sources, one per line)
#   vpnii status            human-readable: "⬡ HomeLab" or "no active tunnels"
#   vpnii clear             remove all manual state files (wg-quick unaffected)
#   vpnii diag              show full vpnii status
#   vpnii setup [-y] [<conf>...]    interactive: chown wg configs, strip stale hooks
#                                   (-y / --yes auto-accepts every prompt)
#   vpnii install [-y] <conf>       copy a clean wg config to /etc/wireguard/
#                                   with the right ownership; checks deps
#   vpnii export [-y] <conf> [<dir>]
#                                   read a wg config, strip vpnii hooks, write
#                                   the clean version to ~/wg/<name>.conf (or <dir>)

set -euo pipefail

VPNII_HOME="${0:A:h:h}"
source "${VPNII_HOME}/lib/vpnii.zsh"

_die()  { printf 'vpnii: %s\n' "$*" >&2; exit 1; }
_info() { printf '  → %s\n' "$*"; }
_ok()   { printf '  \033[0;32m✓\033[0m %s\n' "$*"; }
_warn() { printf '  \033[0;33m⚠\033[0m %s\n' "$*"; }
_err()  { printf '  \033[0;31m✗\033[0m %s\n' "$*"; }
_hdr()  { printf '\n\033[1m%s\033[0m\n' "$*"; }

_usage() {
  cat >&2 <<'EOF'
usage: vpnii <command> [args]

Tunnel state:
  up <tunnel>          mark tunnel active (manual cache only)
  down <tunnel>        mark tunnel inactive (manual cache only)
  list                 list active tunnels — one per line, all sources
  status               human-readable: "⬡ HomeLab" or "no active tunnels"
  clear                remove all manual state files (wg-quick unaffected)

Tools:
  diag                 show full vpnii status
  setup [-y] [<conf>...]
                       interactive: chown wireguard configs and strip stale hooks
                       (no args = scan /etc/wireguard, args = specific files;
                        -y/--yes auto-accepts every prompt)
  install [-y] <conf>  copy a clean wg config to /etc/wireguard/<name>.conf,
                       chown to current user; rejects configs with vpnii hooks
  export [-y] <conf> [<dir>]
                       read a wg config, strip vpnii hooks, write the clean
                       version to ~/wg/<name>.conf (or <dir>); no sudo needed
EOF
  exit 1
}

_validate_name() {
  if [[ -z "$1" || "$1" == */* || "$1" == .* ]]; then
    _die "invalid tunnel name: $1"
  fi
}

# --- Tunnel state ----------------------------------------------------------

_cmd_up() {
  [[ $# -eq 1 ]] || _die "up requires a tunnel name"
  _validate_name "$1"
  if [[ -f "${VPNII_WG_DIR}/${1}.name" ]]; then
    printf 'vpnii: %s is already up via wg-quick — no manual state needed\n' "$1" >&2
    return 0
  fi
  mkdir -p "$VPNII_CACHE_DIR"
  touch "${VPNII_CACHE_DIR}/${1}"
}

_cmd_down() {
  [[ $# -eq 1 ]] || _die "down requires a tunnel name"
  _validate_name "$1"
  local cache_file="${VPNII_CACHE_DIR}/${1}"
  local wg_marker="${VPNII_WG_DIR}/${1}.name"
  # Idempotent: never fail. Legacy PreDown hooks call us while .name still
  # exists — failing here would break tunnel teardown.
  if [[ -f "$cache_file" ]]; then
    rm -f "$cache_file"
  elif [[ -f "$wg_marker" ]]; then
    printf 'vpnii: %s is managed by wg-quick — to bring it down use: sudo wg-quick down %s\n' "$1" "$1" >&2
  fi
}

_cmd_list() {
  vpnii_active_tunnels || true
}

_cmd_status() {
  _vpnii_collect_tunnels
  if (( ${#reply} == 0 )); then
    printf 'no active tunnels\n'
  else
    printf '%s %s\n' "$VPNII_SYM_VPN" "${(j:, :)reply}"
  fi
}

_cmd_clear() {
  if [[ -d "$VPNII_CACHE_DIR" ]]; then
    rm -f "${VPNII_CACHE_DIR}/"*(N.)
  fi
}

# --- Diagnostics -----------------------------------------------------------

_cmd_diag() {
  local zshrc="${ZDOTDIR:-$HOME}/.zshrc"
  printf '\033[1mvpnii diag\033[0m\n'

  _hdr "Active tunnels"
  local found=0 f
  for f in "${VPNII_WG_DIR}"/*.name(N.); do
    _ok "wg-quick: ${f:t:r}  (${f})"
    found=1
  done
  if [[ -d "$VPNII_CACHE_DIR" ]]; then
    for f in "${VPNII_CACHE_DIR}"/*(N.); do
      _ok "state file: ${f:t}  (${f})"
      found=1
    done
  fi
  (( found )) || printf '  no active tunnels\n'

  _hdr "Detection sources"
  if [[ -d "$VPNII_WG_DIR" ]]; then
    _ok "wg-quick dir: $VPNII_WG_DIR"
  else
    _warn "wg-quick dir not found: $VPNII_WG_DIR  (wg-quick not installed?)"
  fi
  if [[ -d "$VPNII_CACHE_DIR" ]]; then
    local cache_files=( "$VPNII_CACHE_DIR"/*(N.) )
    _ok "state dir: $VPNII_CACHE_DIR  (${#cache_files} file(s))"
  else
    _warn "state dir missing: $VPNII_CACHE_DIR  (run install.sh)"
  fi

  _hdr "WireGuard binaries"
  if command -v wg-quick &>/dev/null; then
    _ok "wg-quick: $(command -v wg-quick)"
  else
    _warn "wg-quick not in PATH  (install with: brew install wireguard-tools)"
  fi
  if command -v wg &>/dev/null; then
    _ok "wg: $(command -v wg)"
  else
    _warn "wg not in PATH  (install with: brew install wireguard-tools)"
  fi

  _hdr "vpnii"
  local bin="${VPNII_HOME}/bin/vpnii"
  if [[ -x "$bin" ]]; then
    _ok "binary: $bin"
  else
    _err "binary not found: $bin"
  fi
  if [[ -L "/usr/local/bin/vpnii" ]]; then
    _ok "/usr/local/bin/vpnii → $(readlink /usr/local/bin/vpnii)"
  elif command -v vpnii &>/dev/null; then
    _ok "in PATH: $(command -v vpnii)"
  else
    _warn "not in PATH  (add ${VPNII_HOME}/bin to PATH)"
  fi
  _hdr "Shell integration"
  local zshrc_real="${zshrc:A}"
  if grep -qF "vpnii.plugin.zsh" "$zshrc_real" 2>/dev/null; then
    _ok "sourced in $zshrc"
  else
    _err "not sourced in $zshrc  (run install.sh)"
  fi

  _hdr "WireGuard configs"
  local wg_dir="/etc/wireguard"
  if [[ ! -d "$wg_dir" ]]; then
    printf '  no configs in %s\n' "$wg_dir"
  else
    local any=0 conf
    for conf in "$wg_dir"/*.conf(N.); do
      any=1
      if grep -qE "vpnii(-state)?" "$conf" 2>/dev/null; then
        _warn "${conf:t}: has stale vpnii hooks (harmless, but can be cleaned)"
        printf '      → vpnii setup %s\n' "$conf"
      else
        _ok "${conf:t}: clean"
      fi
    done
    (( any )) || printf '  no .conf files found\n'
  fi

  printf '\n'
}

# --- WireGuard config setup (chown + strip stale hooks) --------------------

typeset -g _VPNII_ASSUME_YES=0

# Interactive yes/no prompt. Defaults to yes (Enter); non-interactive (closed
# stdin) returns no unless --yes was passed, so unattended runs don't make
# destructive guesses by accident.
_ask() {
  local prompt="$1" answer
  if (( _VPNII_ASSUME_YES )); then
    printf '  → %s [Y/n] yes (--yes)\n' "$prompt"
    return 0
  fi
  printf '  → %s [Y/n] ' "$prompt"
  if ! read -r answer; then
    printf 'no (no tty — pass --yes to auto-accept)\n' >&2
    return 1
  fi
  [[ "${answer:l}" != "n" ]]
}

_cmd_setup() {
  while (( $# > 0 )); do
    case "$1" in
      -y|--yes) _VPNII_ASSUME_YES=1; shift ;;
      --) shift; break ;;
      -*) _die "unknown setup flag: $1  (try -y/--yes)" ;;
      *)  break ;;
    esac
  done

  # Explicit configs given → maintenance on those, no auto-detection.
  if (( $# > 0 )); then
    _setup_maintenance "$@"
    return
  fi

  # No args → adaptive: maintenance if /etc/wireguard has configs, wizard if empty.
  local configs=()
  if [[ -d /etc/wireguard ]]; then
    configs=( /etc/wireguard/*.conf(N.) )
  fi
  if (( ${#configs} == 0 )); then
    _setup_wizard
  else
    _setup_maintenance "${configs[@]}"
  fi
}

_setup_maintenance() {
  printf 'vpnii setup — %d config(s) to check\n' "$#"
  local conf
  for conf in "$@"; do
    if [[ ! -e "$conf" ]]; then
      _warn "$conf not found, skipping"
      continue
    fi
    _setup_one "$conf"
  done
  printf '\n'
}

# First-time wizard: triggered when /etc/wireguard is empty/missing.
# Three paths — most users arrive at vpnii already holding a config:
#   1) path to a config file on disk
#   2) paste config content inline (clipboard → ~/wg/<name>.conf with mode
#      0600 from the first byte, never a default-perm tmpfile)
#   3) generate a fresh keypair + skeleton (assist path)
_setup_wizard() {
  printf 'vpnii setup — first-time wizard (no configs in /etc/wireguard)\n\n'

  command -v wg-quick &>/dev/null || _die "wg-quick not found  (install with: brew install wireguard-tools)"
  command -v wg       &>/dev/null || _die "wg not found  (install with: brew install wireguard-tools)"
  _ok "wg-quick: $(command -v wg-quick)"
  _ok "wg:       $(command -v wg)"

  # If a tunnel is already up, warn before letting the user create another.
  # The detection here is the same one used for the prompt indicator —
  # /var/run/wireguard/*.name plus the manual cache dir.
  local active=( ${(f)"$(vpnii_active_tunnels 2>/dev/null)"} )
  if (( ${#active} > 0 )); then
    printf '\n'
    _warn "wg is already running — active tunnel(s):"
    local t
    for t in "${active[@]}"; do printf '      %s\n' "$t"; done
    printf '\n'
    if ! _ask "Continue with setup anyway?"; then
      _info "aborted — tear the tunnel down first if you want a clean slate"
      return 0
    fi
  fi
  printf '\n'

  printf 'What do you have?\n'
  printf '  [1] A path to a wg config file (most common — provider, admin, backup)\n'
  printf '  [2] The config content to paste in (clipboard never hits a tmpfile)\n'
  printf '  [3] Nothing yet — generate a fresh keypair and skeleton\n\n'
  printf '  → Choice [1]: '

  local choice
  read -r choice || _die "aborted"
  : "${choice:=1}"

  case "$choice" in
    1) _wizard_import ;;
    2) _wizard_paste ;;
    3) _wizard_generate ;;
    *) _die "invalid choice: $choice  (expected 1, 2 or 3)" ;;
  esac
}

_wizard_import() {
  printf '\n  → Path to config: '
  local source
  read -r source || _die "aborted"
  source="${source/#\~/$HOME}"
  [[ -n "$source" ]] || _die "path required"
  [[ -f "$source" ]] || _die "not found: $source"
  printf '\n'
  _cmd_install "$source"
}

# Reads pasted config content directly into ~/wg/<name>.conf. The file is
# pre-created with mode 0600 BEFORE any content is appended, so a partial
# paste is never readable by anyone else. CRLF from clipboard apps is
# stripped, and presence of [Interface] / PrivateKey is sanity-checked.
_wizard_paste() {
  printf '\n  → Tunnel name (e.g. HomeLab): '
  local name
  read -r name || _die "aborted"
  [[ -n "$name" ]] || _die "tunnel name required"
  [[ "$name" == */* || "$name" == .* ]] && _die "invalid tunnel name: $name"

  local wg_dir="$HOME/wg"
  mkdir -p "$wg_dir"
  chmod 700 "$wg_dir"
  local conf="$wg_dir/${name}.conf"

  if [[ -e "$conf" ]]; then
    _warn "$conf already exists"
    _ask "Overwrite?" || _die "aborted"
  fi

  : > "$conf"
  chmod 600 "$conf"

  printf '\n'
  printf '  Paste the wg config below. End with a line containing only "EOF",\n'
  printf '  or press Ctrl+D when done:\n\n'

  local line
  while IFS= read -r line; do
    line="${line%$'\r'}"
    [[ "$line" == "EOF" ]] && break
    printf '%s\n' "$line" >> "$conf"
  done

  local size
  size=$(wc -c < "$conf" | tr -d ' ')
  printf '\n'
  _ok "wrote $conf (mode 0600, ${size} bytes)"

  if ! grep -q '^\[Interface\]' "$conf"; then
    _warn "no [Interface] section found — paste might be incomplete"
  fi
  if grep -qE '^PrivateKey\s*=' "$conf"; then
    _ok "PrivateKey present"
  else
    _warn "no PrivateKey line — wg-quick will refuse this config"
  fi

  printf '\n'
  if _ask "Install to /etc/wireguard now?"; then
    printf '\n'
    _cmd_install "$conf"
  else
    printf '\nLater: vpnii install %s\n' "$conf"
  fi
}

# Generates a fresh wg keypair, prompts for peer info, writes the config to
# ~/wg/<name>.conf, prints the public key, then offers to install it.
_wizard_generate() {
  printf '\n'

  local name address peer_pubkey peer_endpoint peer_allowed dns

  printf '  → Tunnel name (e.g. HomeLab): '
  read -r name || _die "aborted"
  [[ -n "$name" ]] || _die "tunnel name required"
  [[ "$name" == */* || "$name" == .* ]] && _die "invalid tunnel name: $name"

  printf '  → Your VPN address with mask (e.g. 192.168.189.100/24): '
  read -r address || _die "aborted"
  [[ -n "$address" ]] || _die "address required"

  printf '  → Server public key: '
  read -r peer_pubkey || _die "aborted"
  [[ -n "$peer_pubkey" ]] || _die "server public key required"

  printf '  → Server endpoint (host:port): '
  read -r peer_endpoint || _die "aborted"
  [[ -n "$peer_endpoint" ]] || _die "endpoint required"

  printf '  → Allowed IPs [0.0.0.0/0]: '
  read -r peer_allowed || _die "aborted"
  : "${peer_allowed:=0.0.0.0/0}"

  printf '  → DNS (optional, blank to skip): '
  read -r dns || _die "aborted"

  local privkey pubkey
  privkey=$(wg genkey)
  pubkey=$(printf '%s' "$privkey" | wg pubkey)

  local wg_dir="$HOME/wg"
  mkdir -p "$wg_dir"
  chmod 700 "$wg_dir"
  local conf="$wg_dir/${name}.conf"

  if [[ -e "$conf" ]]; then
    _warn "$conf already exists"
    _ask "Overwrite?" || _die "aborted"
  fi

  {
    printf '[Interface]\n'
    printf 'PrivateKey = %s\n' "$privkey"
    printf 'Address    = %s\n' "$address"
    [[ -n "$dns" ]] && printf 'DNS        = %s\n' "$dns"
    printf '\n[Peer]\n'
    printf 'PublicKey           = %s\n' "$peer_pubkey"
    printf 'Endpoint            = %s\n' "$peer_endpoint"
    printf 'AllowedIPs          = %s\n' "$peer_allowed"
    printf 'PersistentKeepalive = 25\n'
  } > "$conf"
  chmod 600 "$conf"

  printf '\n'
  _ok "wrote $conf (mode 0600)"
  printf '\n\033[1mYour public key — paste on the server side:\033[0m\n'
  printf '  %s\n\n' "$pubkey"

  if _ask "Install to /etc/wireguard now?"; then
    printf '\n'
    _cmd_install "$conf"
  else
    printf '\nLater: vpnii install %s\n' "$conf"
  fi
}

_setup_one() {
  local conf="$1"
  local name="${conf:t:r}"
  printf '\n\033[1m%s\033[0m  (%s)\n' "$name" "$conf"

  # 1. Ownership — let the user own the file so future edits and cleanups
  # don't need sudo. Skipped if already owned.
  local owner
  owner=$(stat -f '%Su' "$conf" 2>/dev/null || stat -c '%U' "$conf" 2>/dev/null || echo '?')
  if [[ "$owner" == "$USER" ]]; then
    _ok "owned by $USER"
  else
    _warn "owned by $owner — sudo needed for read/write"
    if _ask "Take ownership? (sudo chown $USER:staff $conf)"; then
      sudo chown "$USER:staff" "$conf"
      _ok "now owned by $USER"
    else
      _info "leaving ownership as-is — further steps may need sudo"
    fi
  fi

  # 2. Stale hooks — only check if we can read the file.
  if [[ ! -r "$conf" ]]; then
    _err "not readable — skipping hook check"
    return
  fi
  if grep -qE "vpnii(-state)?" "$conf" 2>/dev/null; then
    _warn "stale vpnii hooks found in PostUp/PreDown"
    if _ask "Strip them?"; then
      _strip_hooks "$conf"
    fi
  else
    _ok "no stale vpnii hooks"
  fi
}

# Reads a wg config from $1, strips ALL known vpnii(-state) PostUp/PreDown
# patterns, writes the result to $2. Source is left untouched. Heredoc keeps
# the python regex readable; both _strip_hooks and _cmd_export call this.
_strip_to_file() {
  python3 - "$1" "$2" <<'PYEOF'
import sys, re

src, dst = sys.argv[1:3]

# Strips ALL known vpnii state-management patterns from PostUp:
#   old claudii: && mkdir -p ...cache/claudii && echo "X" > .../claudii/vpnii
#   su -c form:  && su -c 'vpnii(-state) ...' - $SUDO_USER
#   sudo form:   && sudo -u $SUDO_USER /path/vpnii(-state) up <name>
STRIP_POSTUP = re.compile(
    r'\s*&&\s*(?:'
    r'mkdir\s+-p\s+\S*\.cache\S*\s*&&\s*echo\s+"[^"]*"\s*>\s*\S*/vpnii'
    r"|su\s+-c\s+'vpnii(?:-state)?[^']*'\s+-\s+\S+"
    r'|sudo\s+-u\s+\S+\s+\S*vpnii(?:-state)?\s+\S+\s+\S+'
    r')'
)

# Strips ALL known vpnii state-management patterns from PreDown:
#   old claudii path: /path/.cache/claudii/vpnii
#   su -c form:       && su -c 'vpnii(-state) ...' - $SUDO_USER
#   sudo form:        && sudo -u $SUDO_USER /path/vpnii(-state) down <name>
STRIP_PREDOWN = re.compile(
    r'(?:'
    r'\s+\S+/\.cache\S*/vpnii\b'
    r"|su\s+-c\s+'vpnii(?:-state)?[^']*'\s+-\s+\S+"
    r'|\s*&&\s*sudo\s+-u\s+\S+\s+\S*vpnii(?:-state)?\s+\S+\s+\S+'
    r')'
)

with open(src) as f:
    lines = f.readlines()

out = []
for line in lines:
    if re.match(r'^PostUp\s*=', line):
        out.append(STRIP_POSTUP.sub('', line.rstrip('\n')) + '\n')
    elif re.match(r'^PreDown\s*=', line):
        out.append(STRIP_PREDOWN.sub('', line.rstrip('\n')) + '\n')
    else:
        out.append(line)

with open(dst, 'w') as f:
    f.writelines(out)
PYEOF
}

# Strips hooks in-place. Backup goes to ~/.cache/vpnii/backups/ because
# /etc/wireguard/ stays root-owned (no dir-write for the user).
_strip_hooks() {
  local conf="$1"
  if [[ ! -w "$conf" ]]; then
    _err "not writable — cannot strip"
    return 1
  fi

  local backup_dir="${VPNII_CACHE_DIR}/backups"
  mkdir -p "$backup_dir"
  local backup="${backup_dir}/${conf:t}.$(date +%Y%m%d-%H%M%S).vpnii-bak"
  cp "$conf" "$backup"
  _info "backup: $backup"

  local tmpfile
  tmpfile=$(mktemp)
  _strip_to_file "$conf" "$tmpfile"
  cp "$tmpfile" "$conf"
  rm -f "$tmpfile"
  _ok "stripped (backup at $backup)"
}

# --- WireGuard config install ----------------------------------------------

# Copies a clean wg config into /etc/wireguard/<name>.conf and chowns it to
# the current user, so further edits/cleanups never need sudo. Rejects
# configs containing vpnii hooks — those should be cleaned via `vpnii setup`
# first, since `install` is meant to land already-clean configs.
_cmd_install() {
  while (( $# > 0 )); do
    case "$1" in
      -y|--yes) _VPNII_ASSUME_YES=1; shift ;;
      --) shift; break ;;
      -*) _die "unknown install flag: $1  (try -y/--yes)" ;;
      *)  break ;;
    esac
  done
  [[ $# -eq 1 ]] || _die "usage: vpnii install [-y] <wireguard-config.conf>"
  local source="$1"

  [[ -f "$source" ]] || _die "not found: $source"
  [[ -r "$source" ]] || _die "not readable: $source"

  if ! command -v wg-quick &>/dev/null; then
    _die "wg-quick not found  (install with: brew install wireguard-tools)"
  fi

  if grep -qE "vpnii(-state)?" "$source" 2>/dev/null; then
    _die "$source contains vpnii hooks — clean first: vpnii setup $source"
  fi

  local name="${source:t:r}"
  local target="/etc/wireguard/${name}.conf"

  printf 'vpnii install: %s\n' "$source"
  _info "tunnel name: $name"
  _info "target: $target"
  _ok "wg-quick: $(command -v wg-quick)"
  _ok "source clean (no vpnii hooks)"

  if [[ -e "$target" ]]; then
    _warn "target already exists: $target"
    if ! _ask "Overwrite?"; then
      _info "aborted — nothing changed"
      return 1
    fi
  fi

  if [[ ! -d /etc/wireguard ]]; then
    _info "creating /etc/wireguard"
    sudo mkdir -p /etc/wireguard
    sudo chmod 700 /etc/wireguard
  fi

  _info "sudo cp $source $target"
  sudo cp "$source" "$target"
  _info "sudo chown $USER:staff $target"
  sudo chown "$USER:staff" "$target"
  sudo chmod 600 "$target"

  printf '\n'
  _ok "installed at $target (owned by $USER, mode 0600)"
  printf 'Bring up: sudo wg-quick up %s\n' "$name"
}

# --- WireGuard config export -----------------------------------------------

# Reads a wg config (typically from /etc/wireguard, user-readable when owned),
# strips vpnii hooks, writes the clean version into ~/wg/<name>.conf (or a
# user-supplied directory). No sudo needed. Useful for: extract a clean copy
# you can edit and reinstall via `vpnii install`.
_cmd_export() {
  while (( $# > 0 )); do
    case "$1" in
      -y|--yes) _VPNII_ASSUME_YES=1; shift ;;
      --) shift; break ;;
      -*) _die "unknown export flag: $1  (try -y/--yes)" ;;
      *)  break ;;
    esac
  done
  if (( $# < 1 || $# > 2 )); then
    _die "usage: vpnii export [-y] <wireguard-config.conf> [<dest-dir>]"
  fi

  local source="$1"
  local dest_dir="${2:-$HOME/wg}"

  [[ -f "$source" ]] || _die "not found: $source"
  [[ -r "$source" ]] || _die "not readable: $source (the file is not yours — run 'vpnii setup' first to take ownership)"

  local name="${source:t:r}"
  local target="${dest_dir}/${name}.conf"

  printf 'vpnii export: %s\n' "$source"
  _info "tunnel name: $name"
  _info "target: $target"

  if [[ ! -d "$dest_dir" ]]; then
    mkdir -p "$dest_dir"
    chmod 700 "$dest_dir"
    _ok "created $dest_dir (mode 0700)"
  fi

  if [[ -e "$target" ]]; then
    _warn "target already exists: $target"
    if ! _ask "Overwrite?"; then
      _info "aborted — nothing changed"
      return 1
    fi
  fi

  _strip_to_file "$source" "$target"
  chmod 600 "$target"

  if grep -qE "vpnii(-state)?" "$target" 2>/dev/null; then
    _warn "still contains vpnii references — manual review needed at $target"
  else
    _ok "exported clean to $target (mode 0600)"
  fi

  printf '\nNext steps:\n'
  printf '  edit if needed: %s\n' "$target"
  printf '  install:        vpnii install %s\n' "$target"
}

# --- Dispatcher ------------------------------------------------------------

[[ $# -eq 0 ]] && _usage
cmd="$1"; shift

case "$cmd" in
  up)             _cmd_up "$@" ;;
  down)           _cmd_down "$@" ;;
  list)           _cmd_list ;;
  status)         _cmd_status ;;
  clear)          _cmd_clear ;;
  diag)           _cmd_diag ;;
  setup)          _cmd_setup "$@" ;;
  install)        _cmd_install "$@" ;;
  export)         _cmd_export "$@" ;;
  -h|--help|help) _usage ;;
  *)              _die "unknown command: $cmd  (try 'vpnii help')" ;;
esac
